# ---------------------------------------------------------------------------
# Example environment configuration. Copy to ".env" and fill in your values.
# Do NOT commit the real ".env" file to source control.
# ---------------------------------------------------------------------------

# --- Azure OpenAI (LLM backend for the LangChain agent) ---
AZURE_OPENAI_ENDPOINT=https://your-aoai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Authentication mode:
#   entra (default) -> keyless, uses Microsoft Entra ID (az login / Managed Identity).
#                      Required when API keys are disabled by policy on the resource.
#   key             -> classic API key auth (then set AZURE_OPENAI_API_KEY below).
AZURE_OPENAI_AUTH_MODE=entra
# Credential source for keyless (entra) auth:
#   cli     -> use your 'az login' user (recommended for LOCAL dev)
#   managed -> use the App Service Managed Identity (recommended when DEPLOYED)
#   default -> DefaultAzureCredential (excludes ambient MI in local dev)
AZURE_OPENAI_CREDENTIAL=cli
# Only needed when AZURE_OPENAI_AUTH_MODE=key
AZURE_OPENAI_API_KEY=

# --- Agent metadata ---
AGENT_NAME=Contoso Helpdesk Agent
AGENT_INSTRUCTIONS=You are a helpful enterprise assistant. Be concise and accurate.

# --- Web host (Azure App Service sets PORT automatically) ---
PORT=8000

# --- Microsoft Agent 365 (PREVIEW) ---
# These values are written automatically by the Agent 365 CLI (config sync)
# after "a365 setup all" completes. Leave blank until then.
A365_TENANT_ID=
A365_BLUEPRINT_ID=
A365_AGENT_ID=
A365_CLIENT_ID=
A365_CLIENT_SECRET=
# Set to "true" to enable Agent 365 OpenTelemetry observability export.
A365_OBSERVABILITY_ENABLED=false
