# ===========================================================================
# .gitignore for the Agent 365 Trial repository (root = Agent365-Trial/)
# Protects secrets and generated/local artifacts from being committed.
# ===========================================================================

# --- Python ---
**/.venv/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# --- Secrets & local configuration (NEVER COMMIT) ---
# Real environment file with keys / stamped client secrets
**/.env
# Agent 365 CLI config with tenant/subscription identifiers
**/a365.config.json
# Agent 365 CLI generated state - CONTAINS THE BLUEPRINT CLIENT SECRET
**/a365.generated.config.json
# Any other generated Agent 365 state
**/a365.*.config.json

# --- Agent 365 publish artifacts (generated by 'a365 publish') ---
# The manifest folder embeds tenant/blueprint IDs and is regenerated locally.
**/manifest/

# --- Build / packaging artifacts ---
*.zip
dist/
build/

# --- CLI / diagnostic logs ---
publish*.log
*.log

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# ===========================================================================
# Files that ARE meant to be committed (templates, safe to share):
#   DEV/.env.example
#   DEV/a365.config.template.json
# ===========================================================================
